{
  "$schema": "https://turborepo.dev/schema.json",

  "globalEnv": [
    "NODE_ENV",
    "JWT_SECRET",
    "NEXTAUTH_SECRET",
    "PORT",
    "NEXT_PUBLIC_API_URL",
    "PRISMA_LOGS",
    "DATABASE_URL"
  ],
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "JWT_SECRET",
        "NEXTAUTH_SECRET",
        "PORT",
        "NEXT_PUBLIC_API_URL",
        "PRISMA_LOGS",
        "DATABASE_URL"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "test": {},
    "test:e2e": {}
  }
}
