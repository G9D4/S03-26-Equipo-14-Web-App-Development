generator client {
  provider      = "prisma-client-js"
  // output        = "../src/generated/prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int                   @id @default(autoincrement())
  email               String                @unique
  name                String?
  password            String
  created_at          DateTime              @default(now())
  updated_at          DateTime
  organizationMembers Organization_Member[]
}

model Testimonial {
  id                String            @id @default(uuid())
  type              TestimonialType
  title             String
  content           String
  author            String
  author_photo      String
  author_role       String
  media_url         String
  media_description String
  status            TestimonialStatus @default(pending)
  rating            Decimal
  slug              String
  created_at        DateTime          @default(now())
  updated_at        DateTime
  published_at      DateTime
  testimonialTags   Testimonial_Tag[]
  category_id String
  category Category @relation(fields: [category_id], references: [id])
  member_id String
  member Project_Member @relation(fields: [member_id], references: [id])
  project_id String
  project Project @relation(fields:[project_id], references: [id])

}

model Project {
  id               String          @id @default(uuid())
  name             String
  description      String?
  api_key          String?
  organization     Organization    @relation(fields: [organization_id], references: [id])
  organization_id   String
  created_at       DateTime        @default(now())
  projectMembers    Project_Member[] 
  categories       Category[]
  testimonials Testimonial[]
  tags Tag[]
}

model Organization {
  id                  String                @id @default(uuid())
  name                String
  description         String?
  created_at          DateTime              @default(now())
  projects            Project[]
  organizationMembers Organization_Member[]
}

model Organization_Member {
  id              String            @id @default(uuid())
  user            User              @relation(fields: [user_id], references: [id])
  user_id          Int
  organization    Organization      @relation(fields: [organization_id], references: [id])
  organization_id  String
  projectMembers  Project_Member[]
  role            Organization_Role @default(Editor)
}

model Project_Member {
  id                     String              @id @default(uuid())
  organization_member_id  String
  organization_member    Organization_Member @relation(fields: [organization_member_id], references: [id])
  project                Project @relation(fields:[project_id], references: [id])
  project_id             String
  testimonial_id String? 
  testimonials Testimonial[]
}

model Category {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime
  project    Project  @relation(fields: [project_id], references: [id])
  project_id  String
  testimonial Testimonial[]
}

model Tag {
  id              String            @id @default(uuid())
  name            String
  created_at      DateTime          @default(now())
  updated_at      DateTime
  testimonialTags Testimonial_Tag[]
  projects Project[]
}

model Testimonial_Tag {
  id             String      @id @default(uuid())
  tag_id         String
  tag            Tag         @relation(fields: [tag_id], references: [id])
  testimonial_id String
  testimonial    Testimonial @relation(fields: [testimonial_id], references: [id])
}

enum Organization_Role {
  Owner
  Admin
  Editor
}

enum TestimonialType {
  quote
  case
  video
}

enum TestimonialStatus {
  draft
  pending
  review
  published
  rejected
}
