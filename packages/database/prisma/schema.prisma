generator client {
  provider      = "prisma-client-js"
  // output        = "../src/generated/prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
model User {
   id    Int     @id @default(autoincrement())
   email String  @unique
   name  String?
 }